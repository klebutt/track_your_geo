# Copy to .env and fill in. Never commit .env.

# LiteLLM / provider (at least one provider key required for live runs)
OPENAI_API_KEY= 

# Default model for non-probe LLM calls (LiteLLM format)
TYGEO_MODEL=gpt-4o-mini

# GEO probes: OpenAI search model (web search + url_citation annotations)
TYGEO_PROBE_MODEL=gpt-4o-mini-search-preview

# Search context size for probes: low | medium | high (affects cost)
TYGEO_SEARCH_CONTEXT_SIZE=low

# Optional: base URL if using a proxy
# OPENAI_API_BASE=

# SQLite path (relative to API working directory, or absolute)
TYGEO_DATABASE_URL=sqlite:///./data/tygeo.db

# Directory containing pilot YAML profiles
TYGEO_PILOT_DIR=pilot

# Comma-separated CORS origins (add your Vercel URL in production)
TYGEO_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# DeepEval (optional; for eval suite LLM-as-judge metrics)
# DEEPEVAL_API_KEY=
